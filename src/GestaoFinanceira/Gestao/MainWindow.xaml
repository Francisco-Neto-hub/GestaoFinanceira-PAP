<Window x:Class="Gestao.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestão Financeira - Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Bem-vindo" FontSize="32" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#333"/>

            <Border Background="White" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Email" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtEmail" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Password" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="30" VerticalContentAlignment="Center"/>

                    <Button Content="Entrar" Margin="0,20,0,0" Height="40" Background="#6200EE" Foreground="White" Click="btnLogin_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>